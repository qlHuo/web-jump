{
  "name": "web-jump",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "run-p type-check \"build-only {@}\" -- && npm run sitemap",
    "preview": "pnpm run build-only && wrangler dev",
    "build-only": "vite build",
    "type-check": "vue-tsc --build",
    "lint": "eslint . --ext .vue,.js,.jsx,.ts,.tsx",
    "lint:fix": "eslint . --ext .vue,.js,.ts --fix",
    "format": "prettier --write src/",
    "deploy": "pnpm run build-only && wrangler deploy",
    "sitemap": "tsx scripts/generate-sitemap.ts"
  },
  "dependencies": {
    "dexie": "^4.4.2",
    "pinia": "^3.0.4",
    "sortablejs": "^1.15.7",
    "tdesign-icons-vue-next": "^0.4.4",
    "tdesign-vue-next": "^1.18.6",
    "uuid": "^13.0.0",
    "vue": "^3.5.30",
    "vue-router": "^5.0.3",
    "vue3-draggable-next": "^4.1.4"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.32.2",
    "@tailwindcss/vite": "^4.2.2",
    "@tsconfig/node24": "^24.0.4",
    "@types/dexie": "^1.3.35",
    "@types/node": "^24.12.0",
    "@types/uuid": "^11.0.0",
    "@typescript-eslint/eslint-plugin": "^8.57.2",
    "@typescript-eslint/parser": "^8.57.2",
    "@vitejs/plugin-vue": "^6.0.4",
    "@vitejs/plugin-vue-jsx": "^5.1.5",
    "@vue/eslint-config-typescript": "^14.7.0",
    "@vue/tsconfig": "^0.9.0",
    "eslint": "^10.0.3",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "eslint-plugin-vue": "~10.8.0",
    "jiti": "^2.6.1",
    "less": "^4.6.4",
    "npm-run-all2": "^8.0.4",
    "postcss": "^8.5.8",
    "prettier": "3.8.1",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vite-plugin-vue-devtools": "^8.0.7",
    "vue-eslint-parser": "^10.4.0",
    "vue-tsc": "^3.2.5",
    "wrangler": "^4.82.2"
  },
  "engines": {
    "node": "^20.19.0 || >=22.12.0"
  }
}
